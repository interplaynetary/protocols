{
  "name": "@playnet/free-association",
  "version": "2.0.0",
  "description": "Free Association Protocol - Pure allocation algorithm and recognition system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "source": "./src/index.ts"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js",
      "source": "./src/schemas.ts"
    },
    "./allocation": {
      "types": "./dist/allocation.d.ts",
      "import": "./dist/allocation.js",
      "source": "./src/allocation.ts"
    },
    "./distribution": {
      "types": "./dist/distribution.d.ts",
      "import": "./dist/distribution.js",
      "source": "./src/distribution.ts"
    },
    "./tree": {
      "types": "./dist/tree.d.ts",
      "import": "./dist/tree.js",
      "source": "./src/tree.ts"
    },
    "./itc": {
      "types": "./dist/itc.d.ts",
      "import": "./dist/itc.js",
      "source": "./src/itc.ts"
    },
    "./utils/*": {
      "types": "./dist/utils/*.d.ts",
      "import": "./dist/utils/*.js",
      "source": "./src/utils/*.ts"
    },
    "./filters/*": {
      "types": "./dist/filters/*.d.ts",
      "import": "./dist/filters/*.js",
      "source": "./src/filters/*.ts"
    },
    "./attributes/*": {
      "types": "./dist/attributes/*.d.ts",
      "import": "./dist/attributes/*.js",
      "source": "./src/attributes/*.ts"
    },
    "./collective/*": {
      "types": "./dist/collective/*.d.ts",
      "import": "./dist/collective/*.js",
      "source": "./src/collective/*.ts"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "source": "./src/config.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "version": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "allocation",
    "recognition",
    "mutual-aid",
    "p2p",
    "protocol",
    "free-association"
  ],
  "author": "Free Association Contributors",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/playnet/free-association.git"
  },
  "bugs": {
    "url": "https://github.com/playnet/free-association/issues"
  },
  "homepage": "https://github.com/playnet/free-association#readme",
  "dependencies": {
    "json-logic-js": "^2.0.2",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/json-logic-js": "^2.0.7",
    "@types/node": "^24.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
