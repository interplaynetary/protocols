            Note over Alice: DerivedStateMap[Alice] = {<br/>  shareMap: {Carol: 0.6, Kitchen: 0.4}<br/>}
        end
    and
        rect rgb(240, 248, 255)
            Note over Bob: 📊 COMPUTE DERIVED STATE (Automatic)
            Bob->>Bob: Compute ShareOfGeneralSatisfaction:<br/><br/>Step 1: Calculate influence pools<br/>  Non-Slot node weight: 1.0<br/>  Non-Slot satisfaction: 1.0 (bootstrap)<br/>  P_total = 1.0 × 1.0 = 1.0<br/><br/>Step 2: Calculate recognition pools<br/>  PositivePool = 1.0 / 1.0 = 1.0<br/><br/>Step 3: Calculate raw shares<br/>  Carol: (1.0 × 1.0) × (40/70) = 0.571<br/>  Kitchen: (1.0 × 1.0) × (30/70) = 0.429<br/><br/>Step 4: Apply pool-bounded recognition<br/>  Carol: (0.571 / 1.0) × 1.0 = 0.571<br/>  Kitchen: (0.429 / 1.0) × 1.0 = 0.429<br/><br/>💡 ShareOfTotal-Satisfaction_Bob→Carol = 0.571<br/>💡 ShareOfTotal-Satisfaction_Bob→Kitchen = 0.429
            Note over Bob: DerivedStateMap[Bob] = {<br/>  shareMap: {Carol: 0.571, Kitchen: 0.429}<br/>}
        end
    and
        rect rgb(240, 248, 255)
            Note over Carol: 📊 COMPUTE DERIVED STATE (Automatic)
            Carol->>Carol: Observe network (Alice & Bob's trees):<br/><br/>Alice recognizes Carol: 30 pts (60%)<br/>Bob recognizes Carol: 40 pts (57.1%)<br/><br/>Calculate Mutual-Satisfaction:<br/>  MS(Carol,Alice) = min(ShareTotal_C→A, ShareTotal_A→C)<br/>  Need ShareTotal_Carol→Alice...<br/><br/>💡 Carol doesn't recognize anyone yet (no contributors)<br/>💡 Unilateral recognition only
            Note over Carol: DerivedStateMap[Carol] = {<br/>  mutualSatisfactionMap: {}<br/>}
        end
    and
        rect rgb(240, 248, 255)
