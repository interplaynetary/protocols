        Alice->>Network: Publish Tree {<br/>  Root (entity_id: Alice)<br/>    Non-Slot Node: "Mission Alignment"<br/>      Contributors: [Carol: 30pts, Kitchen: 20pts]<br/>    Goal: "Food Security"<br/>      Need-Slot: {food, declared: 100}<br/>}
